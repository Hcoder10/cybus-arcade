{
  "name": "cybus-arcade",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "npm --prefix packages/wall run build",
    "check": "npm --prefix packages/orchestrator run check && npm --prefix packages/wall run check",
    "bench": "bun run scripts/bench.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
